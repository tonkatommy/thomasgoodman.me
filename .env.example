# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thomasgoodman?schema=public

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/thomasgoodman

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Environment
NODE_ENV=development

# Docker Production (used by docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=thomasgoodman
MONGO_ROOT_USERNAME=mongoadmin
MONGO_ROOT_PASSWORD=change-me-to-a-strong-password

# Optional: Stripe (uncomment when payment features are enabled)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
